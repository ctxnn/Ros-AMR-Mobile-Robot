<?xml version="1.0" ?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="amr_fe01">

  <!--some materials-->
  <xacro:property name="black" value="0.02 0.02 0.02 1.0" />
  <xacro:property name="silver" value="0.5 0.5 0.5 1.0" />
  <xacro:property name="red" value="1.0 0.0 0.0 1.0" />
  <xacro:property name="yellow" value="1.0 1.0 0.0 1.0" />
  <xacro:property name="gray" value="0.3 0.3 0.3 1.0" />
  <xacro:property name="green" value="0.0 0.5 0.0 1.0"/>


  <!--Links-->
  <link name="base_link"/>

  <link name="chassis_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="1.0" />
      <!-- Approximate box inertia: Ixx = (1/12)m*(h^2 + d^2), etc. -->
      <inertia ixx="0.02" iyy="0.03" izz="0.015" ixy="0" iyz="0" ixz="0" />
    </inertial>
    
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://amr_fe01/meshes/chassis_l1.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="1">
        <color rgba="${gray}" />
      </material>
    </visual>
    
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://amr_fe01/meshes/chassis_l2.stl" scale="0.001 0.001 0.001" />
      </geometry>

      <material name="base_link_material">
        <color rgba="${gray}" />
      </material>
    </visual>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://amr_fe01/meshes/chassis_l3.stl" scale="0.001 0.001 0.001" />
      </geometry>

      <material name="2">
        <color rgba="${gray}" />
      </material>
    </visual>

    <collision>
      <origin xyz="0 0.009 0.066" rpy="0 0 0" />
      <geometry>
        <box size="0.16065 0.18 0.1" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.064 0.0105 0.01" />
      <geometry>
        <cylinder radius="0.009" length="0.02" />
      </geometry>
    </collision>
  </link>
  
  <link name="left_wheel_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.2" />
      <inertia ixx="0.0001" iyy="0.0002" izz="0.0001" ixy="0" iyz="0" ixz="0" />
    </inertial>
    <!--Base Link Layer 1 mesh-->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 3.141592653589793" />
      <geometry>
        <mesh filename="package://amr_fe01/meshes/wheel.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="3">
        <color rgba="${black}" />
      </material>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="1.57 0 0" />
      <geometry>
        <cylinder radius="0.035" length="0.02" />
      </geometry>
    </collision>
  </link>

  <link name="right_wheel_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.2" />
      <inertia ixx="0.0001" iyy="0.0002" izz="0.0001" ixy="0" iyz="0" ixz="0" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://amr_fe01/meshes/wheel.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="4">
        <color rgba="${black}" />
      </material>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="1.57 0 0" />
      <geometry>
        <cylinder radius="0.035" length="0.02" />
      </geometry>
    </collision>
  </link>

  <link name="lidar_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.15" />
      <inertia ixx="1e-4" iyy="1e-4" izz="2e-4" ixy="0" iyz="0" ixz="0" />
    </inertial>
    <visual>
      <origin xyz="-0 -9e-06 -0.000115" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://amr_fe01/meshes/lidar_base_link.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="5">
        <color rgba="0.020 0.020 0.020 1.0" />
      </material>
    </visual>
    <visual>
      <origin xyz="0.015 0.01 0.15" />
      <geometry>
        <cylinder radius="0.02" length="0.015" />
      </geometry>
      <material name="6">
        <color rgba="${gray}" />
      </material>
    </visual>

    <collision>
      <origin xyz="0.015 0.01 0.13" rpy="0 0 0" />
      <geometry>
        <box size="0.06 0.06 0.06" />
      </geometry>
    </collision>
  </link>

  <link name="camera_link"> 
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.05" />
      <inertia ixx="1e-4" iyy="1e-4" izz="2e-4" ixy="0" iyz="0" ixz="0" />
    </inertial>

    <visual>
      <origin xyz="0.06 0.005 0.09" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.04 0.02"/>
      </geometry>
      <material name="camera_material">
        <color rgba="${green}"/>
      </material>
    </visual>
  </link>


  <!-- Joints-->
  <joint name="base_link_to_chassis_link" type="fixed">
    <parent link="base_link"/>
    <child link="chassis_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="camera_link_to_chassis_link" type="fixed">
    <parent link="chassis_link"/>
    <child link="camera_link"/>
    <origin xyz="0 0 0" rpy="0 0 0" />
  </joint>

  <joint name="left_wheel_link_to_chassis_link_joint" type="continuous">
    <parent link="chassis_link" />
    <child link="left_wheel_link" />
    <origin xyz="0.051 0.1125 0.034" rpy="0 0 0" />
    <axis xyz="0.0 1.0 0.0" />
  </joint>

  <joint name="right_wheel_link_to_chassis_link_joint" type="continuous">
    <origin xyz="0.051 -0.0925 0.034" rpy="0 0 0" />
    <parent link="chassis_link" />
    <child link="right_wheel_link" />
    <axis xyz="0.0 1.0 0.0" />
  </joint>

  <joint name="lidar_link_to_chassis_link_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="chassis_link" />
    <child link="lidar_link" />
  </joint>

  <!--Gazebo Plugins and Sensors-->
  <gazebo> 
    <!-- Sensors system plugin -->
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <!-- Diff drive plugin -->
    <plugin filename="gz-sim-diff-drive-system" 
            name="gz::sim::systems::DiffDrive">

      <left_joint>left_wheel_link_to_chassis_link_joint</left_joint>
      <right_joint>right_wheel_link_to_chassis_link_joint</right_joint>
      <!-- kinematics -->
      <wheel_separation>0.205</wheel_separation>
      <wheel_radius>0.035</wheel_radius>

      <!-- limits -->
      <max_linear_acceleration>1</max_linear_acceleration>
      <min_linear_acceleration>-1</min_linear_acceleration>
      <max_angular_acceleration>2</max_angular_acceleration>
      <min_angular_acceleration>-2</min_angular_acceleration>
      <max_linear_velocity>0.5</max_linear_velocity>
      <min_linear_velocity>-0.5</min_linear_velocity>
      <max_angular_velocity>1</max_angular_velocity>
      <min_angular_velocity>-1</min_angular_velocity>

      <!-- input -->
      <topic>/amr_fe01/cmd_vel</topic>

      <!-- output -->
      <odom_topic>/amr_fe01/odom</odom_topic>
      <tf_topic>/tf</tf_topic>

      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>

    <!-- Joint state publisher plugin -->
    <plugin
      filename="gz-sim-joint-state-publisher-system"
      name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
    </plugin>
  </gazebo>

  <!-- Lidar Sensor -->
  <gazebo reference="lidar_link">
    <sensor name="gpu_lidar" type="gpu_lidar">
      <pose>0.015 0.01 0.15 0 0 0</pose>
      <topic>/scan</topic>
      <update_rate>10</update_rate>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <gz_frame_id>lidar_link</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.1</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
    </sensor>
  </gazebo>

  <!-- Camera Sensor -->
  <gazebo reference="camera_link">
    <sensor name="rgb_camera" type="camera">
      <pose>0.06 0.005 0.09 0 0 0</pose>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>30.0</update_rate>
      <topic>/rgb_camera/image</topic>
      <camera>
        <horizontal_fov>1.047198</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>10</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>
</robot>